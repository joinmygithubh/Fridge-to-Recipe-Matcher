# ── Server environment ─────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# MongoDB Atlas connection string (mongodb+srv://...). Local MongoDB is NOT used.
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/fridge-recipe-matcher?retryWrites=true&w=majority

# URL of the client app, used for CORS
CLIENT_URL=http://localhost:5173

# JSON Web Token settings
JWT_SECRET=replace-this-with-a-long-random-secret-string
JWT_EXPIRES_IN=7d
